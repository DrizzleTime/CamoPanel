services:
  db:
    image: postgres:16
    restart: unless-stopped
    environment:
      POSTGRES_DB: {{ .Values.database }}
      POSTGRES_USER: {{ .Values.username }}
      POSTGRES_PASSWORD: {{ .Values.password }}
    ports:
      - "{{ .Values.port }}:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data

volumes:
  postgres-data:

